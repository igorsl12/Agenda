# Variáveis de ambiente (Expo Web lê o prefixo EXPO_PUBLIC_ no browser).
# Copie para .env e preencha. O .env NÃO deve ser commitado (já está no .gitignore).

# Provedor de IA: "mock" (padrão, sem credencial) | "gemini" | "groq" | "openai"
# Se deixar vazio, o app auto-detecta: usa gemini/openai se a respectiva chave existir.
EXPO_PUBLIC_AI_PROVIDER=

# Google Gemini (roda direto do navegador, sem CORS). Pegue em: https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=

# OpenAI (opcional). Pegue em: https://platform.openai.com/api-keys
EXPO_PUBLIC_OPENAI_API_KEY=
EXPO_PUBLIC_OPENAI_MODEL=gpt-4o-mini

# Groq (API compatível com OpenAI; Whisper large v3 + modelos abertos gpt-oss).
# Pegue em: https://console.groq.com/keys
EXPO_PUBLIC_GROQ_API_KEY=
EXPO_PUBLIC_GROQ_MODEL=openai/gpt-oss-20b

# URL do proxy de IA (recomendado p/ distribuicao — ver server/README.md).
# Com a URL definida, ela tem prioridade sobre as chaves diretas acima.
EXPO_PUBLIC_AI_PROXY_URL=
