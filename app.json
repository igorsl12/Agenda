{
  "expo": {
    "name": "Agenda Inteligente",
    "slug": "agenda-dinamica-inteligente",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F5F5F7"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.iagoslima.agenda",
      "icon": "./assets/icon.png"
    },
    "android": {
      "package": "com.iagoslima.agenda",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F5F5F7"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
