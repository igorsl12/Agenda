{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/extract.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/extract",
      "destination": "/api/extract"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
