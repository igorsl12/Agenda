# Chaves de IA do PROXY (server-side — NUNCA use prefixo EXPO_PUBLIC aqui).
# Preencha apenas UMA; auto-detecção: Gemini > Groq > OpenAI.
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Opcionais
# OPENAI_MODEL=gpt-4o-mini
# GROQ_MODEL=openai/gpt-oss-20b
# PORT=8787
# ALLOWED_ORIGIN=*

# Segredo compartilhado opcional: se definido, o app deve enviar X-Proxy-Token igual
# (EXPO_PUBLIC_AI_PROXY_TOKEN no .env do app).
PROXY_AUTH_TOKEN=

# Rate limit por IP (requisicoes por minuto). Padrao: 10.
RATE_LIMIT_MAX=
