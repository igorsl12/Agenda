{
  "expo": {
    "name": "AgendIA",
    "slug": "agenda-dinamica-inteligente",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F5F7"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.iagoslima.agenda",
      "icon": "./assets/icon.png"
    },
    "android": {
      "package": "com.iagoslima.agenda",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F5F5F7"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "Permita o acesso ao microfone para agendar compromissos por voz."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#2E6BF0"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "cea72946-c85f-4151-ac21-e182b1ae20ab"
      }
    }
  }
}
